        "navLabel": "史镇萍 老师",
        "teacherName": "史镇萍老师",
        "role": "英语老师 · 班主任",
        "titleMain": "师恩咏",
        "poemLines": [
            "史笔殷勤记岁年，",
            "镇日躬耕桃李前。",
            "萍影初逢秋月圆，",
            "恩波浩荡润心泉。",
            "师门初掌志犹坚，",
            "严规偶震似惊弦。",
            "慈语频传如暖烟，",
            "相陪三载共书篇。",
            "济世何须八百言，",
            "润物无声夜雨绵。",
            "无言桃李自芳妍，",
            "声绕杏梁忆昔年。"
        ],
        "annotation": "NULL:JSON_annotation",
        "extraNote": "NULL:JSON_extraNote"
    },
