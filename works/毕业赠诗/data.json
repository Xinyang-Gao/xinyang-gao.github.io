        "teacherName": "张翠萍老师",
        "role": "九年级数学老师",
        "titleMain": "临江仙·赠张翠萍老师",
        "poemLines": [
            "张袖拂开迷雾，翠枝垂下浓阴。",
            "萍踪常伴数形深。",
            "卷间朱笔暖，灯下墨痕深。",
            "巧语解开心锁，难题化做微吟。",
            "细心批改到宵沉。",
            "不言桃李满，但记此时心。"
        ],
        "annotation": "NULL:JSON_annotation",
        "extraNote": "NULL:JSON_extraNote"
